# Environment variables for Book Sales Website
# Create a copy of this file named .env and update with your actual credentials

# Flask configuration
SECRET_KEY=your_secret_key_here
DATABASE_URI=sqlite:///booksales.db

# PayPal configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Email provider: auto | mcp | sendgrid | smtp
EMAIL_PROVIDER=auto

# SMTP fallback
SMTP_FROM=no-reply@example.com
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USE_TLS=true

# Optional SendGrid fallback
# SENDGRID_API_KEY=your_sendgrid_api_key

# Merchant copy destination (used when no admin email is found)
MERCHANT_EMAIL=merchant@example.com

# MCP email server defaults to npm package mcp-send-email.
# Official server: https://github.com/resend/resend-mcp
MCP_EMAIL_SERVER_COMMAND=npx
MCP_EMAIL_SERVER_ARGS=-y resend-mcp
# Optional explicit tool name, for example: send_email
# MCP_EMAIL_TOOL_NAME=send_email

# Resend MCP configuration (required for stdio mode)
RESEND_API_KEY=re_xxxxxxxxx
# Use a verified domain sender to avoid interactive prompts/failures
SENDER_EMAIL_ADDRESS=no-reply@yourdomain.com

# Optional: published Resend template ID used for invoice emails.
# When set, invoice sends use Resend templates first and fall back if needed.
# RESEND_INVOICE_TEMPLATE_ID=tpl_xxxxxxxxx
